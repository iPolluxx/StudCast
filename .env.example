GEMINI_API_KEY=
EMAIL_USER=
EMAIL_PASS=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Twilio A2P 10DLC Configuration
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
# Set to 'true' ONLY after the Twilio 10DLC A2P campaign is approved.
# While false (or unset), OTP delivery uses the email fallback because
# Twilio accepts unregistered sends ("queued") but carriers reject them
# async with error 30034 — which would otherwise falsely report success.
SMS_LIVE=false

# Seed user (optional — only needed on fresh Firestore environments)
SEED_PHONE=+1XXXXXXXXXX
SEED_EMAIL=you@example.com
SEED_ZIP=00000
